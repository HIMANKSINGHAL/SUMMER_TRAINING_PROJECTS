   "source": [
    "#IMAGE IMPORT : COLOR GRADING\n",
    "import numpy as np\n",
    "from PIL import Image \n",
    "import matplotlib.pyplot as plt\n",
    "img = Image.open(\"strawberry.jpeg\")\n",
    "img = np.array(img)\n",
    "\n",
    "img[:,:,0] = np.clip(img[:,:,0]+255,255,0)\n",
    "\n",
    "plt.imshow(img)\n",
    "plt.axis(\"Off\")\n",
    "plt.show()\n"
   ]
